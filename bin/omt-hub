#!/bin/bash
# omt-hub — Persistent session manager for Oh My Team
# Keeps multiple project sessions alive in tmux
#
# Usage:
#   omt-hub start ~/projects/my-app          Start a session for a project
#   omt-hub start ~/projects/my-app --telegram  Start with Telegram channel
#   omt-hub list                              List all active sessions
#   omt-hub attach my-app                     Attach to a session
#   omt-hub stop my-app                       Stop a session
#   omt-hub stop-all                          Stop all sessions
#   omt-hub status                            Show status of all sessions

PLUGIN_DIR="$HOME/.oh-my-team"
HUB_SESSION="omt-hub"

CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# Derive session name from project path
session_name() {
    basename "$1" | tr '.' '-' | tr ' ' '-'
}

cmd_start() {
    local PROJECT_DIR="$1"
    shift

    if [ -z "$PROJECT_DIR" ]; then
        echo -e "${RED}Usage: omt-hub start <project-directory> [--telegram|--discord|--imessage]${RESET}"
        exit 1
    fi

    # Resolve to absolute path
    PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
        echo -e "${RED}Directory not found: $1${RESET}"
        exit 1
    }

    local NAME=$(session_name "$PROJECT_DIR")

    # Check if already running
    if tmux has-session -t "omt-$NAME" 2>/dev/null; then
        echo -e "${YELLOW}Session omt-$NAME already running. Use: omt-hub attach $NAME${RESET}"
        return 1
    fi

    # Build claude command
    local CLAUDE_CMD="cd '$PROJECT_DIR' && claude --plugin-dir '$PLUGIN_DIR' --dangerously-skip-permissions"

    # Handle channel flags
    for arg in "$@"; do
        case "$arg" in
            --telegram)
                CLAUDE_CMD="$CLAUDE_CMD --channels plugin:telegram@claude-plugins-official"
                ;;
            --discord)
                CLAUDE_CMD="$CLAUDE_CMD --channels plugin:discord@claude-plugins-official"
                ;;
            --imessage)
                CLAUDE_CMD="$CLAUDE_CMD --channels plugin:imessage@claude-plugins-official"
                ;;
            --channels=*)
                CLAUDE_CMD="$CLAUDE_CMD --channels ${arg#--channels=}"
                ;;
        esac
    done

    # Start detached tmux session
    tmux new-session -d -s "omt-$NAME" "$CLAUDE_CMD; echo 'Session ended. Press any key...'; read -n1"

    echo -e "${GREEN}${BOLD}Started:${RESET} omt-$NAME"
    echo -e "  ${DIM}Project:${RESET} $PROJECT_DIR"
    echo -e "  ${DIM}Attach:${RESET}  omt-hub attach $NAME"

    # Check for channels
    for arg in "$@"; do
        case "$arg" in
            --telegram) echo -e "  ${DIM}Channel:${RESET} Telegram (pair with /telegram:access pair <code>)" ;;
            --discord)  echo -e "  ${DIM}Channel:${RESET} Discord (pair with /discord:access pair <code>)" ;;
            --imessage) echo -e "  ${DIM}Channel:${RESET} iMessage (text yourself to start)" ;;
        esac
    done
}

cmd_list() {
    local SESSIONS=$(tmux list-sessions 2>/dev/null | grep "^omt-" | cut -d: -f1)

    if [ -z "$SESSIONS" ]; then
        echo -e "${DIM}No active sessions. Start one with: omt-hub start <project-dir>${RESET}"
        return
    fi

    echo -e "${BOLD}Active Oh My Team sessions:${RESET}"
    echo ""
    while IFS= read -r session; do
        local NAME="${session#omt-}"
        local CREATED=$(tmux display-message -t "$session" -p '#{session_created}' 2>/dev/null)
        local WINDOWS=$(tmux display-message -t "$session" -p '#{session_windows}' 2>/dev/null)

        # Get the working directory from the first pane
        local CWD=$(tmux display-message -t "$session" -p '#{pane_current_path}' 2>/dev/null)

        echo -e "  ${GREEN}${BOLD}$NAME${RESET}"
        echo -e "    ${DIM}Path:${RESET}    $CWD"
        echo -e "    ${DIM}Windows:${RESET} $WINDOWS"
        echo -e "    ${DIM}Attach:${RESET}  omt-hub attach $NAME"
        echo ""
    done <<< "$SESSIONS"
}

cmd_attach() {
    local NAME="$1"
    if [ -z "$NAME" ]; then
        echo -e "${RED}Usage: omt-hub attach <session-name>${RESET}"
        cmd_list
        exit 1
    fi

    if ! tmux has-session -t "omt-$NAME" 2>/dev/null; then
        echo -e "${RED}Session omt-$NAME not found.${RESET}"
        cmd_list
        exit 1
    fi

    tmux attach-session -t "omt-$NAME"
}

cmd_stop() {
    local NAME="$1"
    if [ -z "$NAME" ]; then
        echo -e "${RED}Usage: omt-hub stop <session-name>${RESET}"
        exit 1
    fi

    if tmux has-session -t "omt-$NAME" 2>/dev/null; then
        tmux kill-session -t "omt-$NAME"
        echo -e "${GREEN}Stopped: omt-$NAME${RESET}"
    else
        echo -e "${YELLOW}Session omt-$NAME not found.${RESET}"
    fi
}

cmd_stop_all() {
    local SESSIONS=$(tmux list-sessions 2>/dev/null | grep "^omt-" | cut -d: -f1)

    if [ -z "$SESSIONS" ]; then
        echo -e "${DIM}No active sessions.${RESET}"
        return
    fi

    while IFS= read -r session; do
        tmux kill-session -t "$session"
        echo -e "${GREEN}Stopped: $session${RESET}"
    done <<< "$SESSIONS"
}

cmd_status() {
    local SESSIONS=$(tmux list-sessions 2>/dev/null | grep "^omt-" | cut -d: -f1)
    local COUNT=$(echo "$SESSIONS" | grep -c "^omt-" 2>/dev/null || echo "0")

    echo -e "${BOLD}Oh My Team Hub${RESET}"
    echo -e "  Sessions: ${GREEN}$COUNT active${RESET}"
    echo -e "  Plugin:   $PLUGIN_DIR"
    echo ""

    if [ -n "$SESSIONS" ] && [ "$SESSIONS" != "" ]; then
        cmd_list
    fi
}

# Main command router
case "${1:-status}" in
    start)   shift; cmd_start "$@" ;;
    list|ls) cmd_list ;;
    attach|a) shift; cmd_attach "$@" ;;
    stop)    shift; cmd_stop "$@" ;;
    stop-all) cmd_stop_all ;;
    status)  cmd_status ;;
    help|-h|--help)
        echo "omt-hub — Persistent session manager for Oh My Team"
        echo ""
        echo "Usage:"
        echo "  omt-hub start <dir> [--telegram|--discord]  Start a project session"
        echo "  omt-hub list                                 List active sessions"
        echo "  omt-hub attach <name>                        Attach to a session"
        echo "  omt-hub stop <name>                          Stop a session"
        echo "  omt-hub stop-all                             Stop all sessions"
        echo "  omt-hub status                               Show hub status"
        echo ""
        echo "Examples:"
        echo "  omt-hub start ~/projects/my-app"
        echo "  omt-hub start ~/projects/my-app --telegram"
        echo "  omt-hub attach my-app"
        echo "  omt-hub stop my-app"
        ;;
    *)
        echo -e "${RED}Unknown command: $1${RESET}"
        echo "Run: omt-hub help"
        exit 1
        ;;
esac
