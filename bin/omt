#!/bin/bash
# omt — Oh My Team CLI
# Single entry point for interactive sessions and hub management
#
# Usage:
#   omt                         Start interactive session (in tmux)
#   omt -d                      Start with auto-approve (danger mode)
#   omt hub init --telegram <token> --chat-id <id>  Configure hub
#   omt hub start               Start router + hub session
#   omt hub add <dir>           Start a project session with bridge
#   omt hub remove <name>       Stop a project session
#   omt hub list                List active sessions
#   omt hub status              Overview
#   omt hub stop                Stop everything

# Colors
CYAN='\033[36m'; GREEN='\033[32m'; YELLOW='\033[33m'; RED='\033[31m'
BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# Resolve plugin directory
if [ -d "$HOME/.oh-my-team/agents" ]; then
    PLUGIN_DIR="$HOME/.oh-my-team"
elif [ -d "$(dirname "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")")/agents" ]; then
    PLUGIN_DIR="$(dirname "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")")"
else
    echo -e "${RED}Error: Oh My Team plugin not found.${RESET}"
    echo "Run: npm i -g oh-my-team"
    exit 1
fi

OMT_DIR="$HOME/.oh-my-team"
CHANNEL_DIR="$PLUGIN_DIR/channel"
CONFIG_PATH="$OMT_DIR/hub-config.json"
ROUTER_PORT="${ROUTER_PORT:-8800}"
NEXT_BRIDGE_PORT_FILE="$OMT_DIR/.next-bridge-port"

# ── Utility functions ───────────────────────────────────────────────────

session_name_from_path() {
    basename "$1" | tr './ ' '-'
}

next_bridge_port() {
    if [ -f "$NEXT_BRIDGE_PORT_FILE" ]; then
        local port=$(cat "$NEXT_BRIDGE_PORT_FILE")
        echo $((port + 1)) > "$NEXT_BRIDGE_PORT_FILE"
        echo "$port"
    else
        mkdir -p "$OMT_DIR"
        echo "8802" > "$NEXT_BRIDGE_PORT_FILE"
        echo "8801"
    fi
}

require_bun() {
    if ! command -v bun &>/dev/null; then
        echo -e "${RED}Error: Bun is required for hub features.${RESET}"
        echo "Install: curl -fsSL https://bun.sh/install | bash"
        exit 1
    fi
}

require_config() {
    if [ ! -f "$CONFIG_PATH" ]; then
        echo -e "${RED}Hub not configured. Run: omt hub init --telegram <token> --chat-id <id>${RESET}"
        exit 1
    fi
}

require_router() {
    if ! curl -s "http://localhost:$ROUTER_PORT/health" > /dev/null 2>&1; then
        echo -e "${RED}Router not running. Run: omt hub start${RESET}"
        exit 1
    fi
}

# ── Hub commands ────────────────────────────────────────────────────────

hub_init() {
    local PLATFORM="" TOKEN="" CHAT_ID=""

    # Parse flags if provided (non-interactive mode)
    while [ $# -gt 0 ]; do
        case "$1" in
            --telegram)  PLATFORM="telegram"; shift ;;
            --discord)   PLATFORM="discord"; shift ;;
            --slack)     PLATFORM="slack"; shift ;;
            --token)     TOKEN="$2"; shift 2 ;;
            --chat-id)   CHAT_ID="$2"; shift 2 ;;
            *)           shift ;;
        esac
    done

    mkdir -p "$OMT_DIR"

    echo ""
    echo -e "${CYAN}${BOLD}  Oh My Team Hub Setup${RESET}"
    echo ""

    # Step 1: Choose platform
    if [ -z "$PLATFORM" ]; then
        echo -e "  ${BOLD}Step 1:${RESET} Choose your messaging platform"
        echo ""
        echo -e "    ${GREEN}1)${RESET} Telegram  ${DIM}(recommended — Forum Topics for per-project threads)${RESET}"
        echo -e "    ${DIM}2) Discord   (coming soon)${RESET}"
        echo -e "    ${DIM}3) Slack     (coming soon)${RESET}"
        echo ""
        read -p "  Choose [1]: " choice
        choice=${choice:-1}
        case "$choice" in
            1) PLATFORM="telegram" ;;
            2) echo -e "\n  ${YELLOW}Discord adapter not yet implemented.${RESET}"; exit 1 ;;
            3) echo -e "\n  ${YELLOW}Slack adapter not yet implemented.${RESET}"; exit 1 ;;
            *) echo -e "\n  ${RED}Invalid choice.${RESET}"; exit 1 ;;
        esac
    fi

    if [ "$PLATFORM" = "telegram" ]; then
        # Step 2: Bot token
        if [ -z "$TOKEN" ]; then
            echo ""
            echo -e "  ${BOLD}Step 2:${RESET} Create a Telegram bot"
            echo ""
            echo -e "    1. Open Telegram and search for ${CYAN}@BotFather${RESET}"
            echo -e "    2. Send ${CYAN}/newbot${RESET}"
            echo -e "    3. Give it a name (e.g., \"My Dev Team\")"
            echo -e "    4. Give it a username (e.g., \"mydevteam_bot\")"
            echo -e "    5. Copy the token BotFather gives you"
            echo ""
            read -p "  Paste your bot token: " TOKEN
            if [ -z "$TOKEN" ]; then
                echo -e "  ${RED}Token is required.${RESET}"
                exit 1
            fi
        fi

        # Verify token
        echo -e "  ${DIM}Verifying bot token...${RESET}"
        local bot_info=$(curl -s "https://api.telegram.org/bot${TOKEN}/getMe")
        if echo "$bot_info" | grep -q '"ok":true'; then
            local bot_name=$(echo "$bot_info" | python3 -c "import json,sys; print(json.load(sys.stdin)['result']['username'])" 2>/dev/null || echo "your bot")
            echo -e "  ${GREEN}Connected to @${bot_name}${RESET}"
        else
            echo -e "  ${RED}Invalid token. Check and try again.${RESET}"
            exit 1
        fi

        # Step 3: Create group
        if [ -z "$CHAT_ID" ]; then
            echo ""
            echo -e "  ${BOLD}Step 3:${RESET} Create a Telegram group"
            echo ""
            echo -e "    1. Create a new group in Telegram (name it e.g., \"Oh My Team Hub\")"
            echo -e "    2. Add ${CYAN}@${bot_name}${RESET} to the group"
            echo -e "    3. Make the bot ${BOLD}admin${RESET} (Group Settings → Administrators → Add)"
            echo -e "    4. Enable ${BOLD}Topics${RESET} (Group Settings → Topics → ON)"
            echo -e "    5. Send any message in the group"
            echo ""
            read -p "  Done? Press Enter, then I'll detect the chat ID... " _

            echo -e "  ${DIM}Looking for the group...${RESET}"
            local updates=$(curl -s "https://api.telegram.org/bot${TOKEN}/getUpdates")
            CHAT_ID=$(echo "$updates" | python3 -c "
import json, sys
data = json.load(sys.stdin)
if data.get('ok') and data.get('result'):
    for update in reversed(data['result']):
        msg = update.get('message', {})
        chat = msg.get('chat', {})
        if chat.get('type') in ('group', 'supergroup'):
            print(chat['id'])
            sys.exit(0)
print('')
" 2>/dev/null)

            if [ -z "$CHAT_ID" ]; then
                echo -e "  ${YELLOW}Couldn't auto-detect. Let me try another way...${RESET}"
                echo ""
                echo -e "    Open this URL in your browser:"
                echo -e "    ${CYAN}https://api.telegram.org/bot${TOKEN}/getUpdates${RESET}"
                echo ""
                echo -e "    Look for: ${BOLD}\"chat\":{\"id\":-100XXXXXXXXXX}${RESET}"
                echo ""
                read -p "  Paste the chat ID (starts with -100): " CHAT_ID
                if [ -z "$CHAT_ID" ]; then
                    echo -e "  ${RED}Chat ID is required.${RESET}"
                    exit 1
                fi
            else
                echo -e "  ${GREEN}Found group: ${CHAT_ID}${RESET}"
            fi
        fi

        # Verify group access
        echo -e "  ${DIM}Verifying group access...${RESET}"
        local chat_info=$(curl -s "https://api.telegram.org/bot${TOKEN}/getChat?chat_id=${CHAT_ID}")
        if echo "$chat_info" | grep -q '"ok":true'; then
            local group_name=$(echo "$chat_info" | python3 -c "import json,sys; print(json.load(sys.stdin)['result'].get('title','Group'))" 2>/dev/null || echo "Group")
            echo -e "  ${GREEN}Connected to \"${group_name}\"${RESET}"
        else
            echo -e "  ${RED}Cannot access group. Make sure the bot is added and is admin.${RESET}"
            exit 1
        fi

        # Save config
        cat > "$CONFIG_PATH" << EOF
{
  "platform": "telegram",
  "credentials": {
    "botToken": "$TOKEN",
    "chatId": "$CHAT_ID"
  }
}
EOF

        echo ""
        echo -e "  ${GREEN}${BOLD}Hub configured!${RESET}"
        echo ""
        echo -e "  ${DIM}Platform:${RESET} Telegram"
        echo -e "  ${DIM}Bot:${RESET}      @${bot_name}"
        echo -e "  ${DIM}Group:${RESET}    ${group_name} (${CHAT_ID})"
        echo ""
        echo -e "  Next: ${CYAN}omt hub start${RESET}"
        echo ""
    fi
}

hub_start() {
    require_bun
    require_config

    # Install channel deps if needed
    if [ ! -d "$CHANNEL_DIR/node_modules" ]; then
        echo -e "${YELLOW}Installing channel dependencies...${RESET}"
        (cd "$CHANNEL_DIR" && bun install --no-summary 2>&1)
    fi

    # Start the router
    if tmux has-session -t "omt-router" 2>/dev/null; then
        echo -e "${YELLOW}Router already running.${RESET}"
    else
        echo -e "${GREEN}Starting router on port $ROUTER_PORT...${RESET}"
        tmux new-session -d -s "omt-router" \
            "cd '$CHANNEL_DIR' && OMT_HUB_DIR='$OMT_DIR' ROUTER_PORT=$ROUTER_PORT bun run router.ts 2>&1 | tee '$OMT_DIR/router.log'; echo 'Router stopped. Press any key...'; read -n1"

        # Wait for router to be ready
        local retries=0
        while ! curl -s "http://localhost:$ROUTER_PORT/health" > /dev/null 2>&1; do
            sleep 0.5
            retries=$((retries + 1))
            if [ $retries -gt 20 ]; then
                echo -e "${RED}Router failed to start. Check: omt hub logs${RESET}"
                exit 1
            fi
        done
        echo -e "${GREEN}Router ready.${RESET}"
    fi

    # Start the hub Claude session with a bridge connected to General topic
    local HUB_BRIDGE_PORT=8801
    if tmux has-session -t "omt-hub" 2>/dev/null; then
        echo -e "${YELLOW}Hub session already running.${RESET}"
    else
        echo -e "${GREEN}Starting hub session (bridge on port $HUB_BRIDGE_PORT)...${RESET}"

        # Reset next bridge port to start after hub's port
        echo "8802" > "$NEXT_BRIDGE_PORT_FILE"

        tmux new-session -d -s "omt-hub" \
            "cd '$HOME' && \
             BRIDGE_PORT=$HUB_BRIDGE_PORT \
             ROUTER_URL=http://localhost:$ROUTER_PORT \
             SESSION_NAME=hub \
             claude --plugin-dir '$PLUGIN_DIR' \
               --agent hub \
               --dangerously-skip-permissions \
               --dangerously-load-development-channels server:omt-bridge; \
             echo 'Hub stopped. Press any key...'; read -n1"

        # Wait for hub bridge to be ready
        local retries=0
        while ! curl -s "http://localhost:$HUB_BRIDGE_PORT/health" > /dev/null 2>&1; do
            sleep 0.5
            retries=$((retries + 1))
            if [ $retries -gt 30 ]; then
                echo -e "${RED}Hub bridge failed to start. Check: omt hub attach${RESET}"
                break
            fi
        done

        # Register hub as a session for the General topic
        if curl -s "http://localhost:$HUB_BRIDGE_PORT/health" > /dev/null 2>&1; then
            curl -s -X POST "http://localhost:$ROUTER_PORT/sessions" \
                -H "Content-Type: application/json" \
                -d "{\"name\": \"hub\", \"path\": \"$HOME\", \"bridgePort\": $HUB_BRIDGE_PORT, \"isHub\": true}" > /dev/null 2>&1
            echo -e "${GREEN}Hub session ready. Listening on Telegram General topic.${RESET}"
        fi
    fi

    echo ""
    echo -e "${GREEN}${BOLD}Oh My Team Hub is running.${RESET}"
    echo ""
    echo -e "  ${DIM}Router:${RESET}    http://localhost:$ROUTER_PORT"
    echo -e "  ${DIM}Hub:${RESET}       http://localhost:$HUB_BRIDGE_PORT"
    echo -e "  ${DIM}Attach:${RESET}    omt hub attach"
    echo -e "  ${DIM}Telegram:${RESET}  Send a message in the General topic"
    echo ""
    echo -e "  Add projects: ${CYAN}omt hub add <project-dir>${RESET}"
    echo -e "  From Telegram: send \"start ~/projects/my-app\" in General"
}

hub_add() {
    local PROJECT_DIR="$1"
    shift 2>/dev/null

    if [ -z "$PROJECT_DIR" ]; then
        echo -e "${RED}Usage: omt hub add <project-directory>${RESET}"
        exit 1
    fi

    require_router

    # Resolve to absolute path
    PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
        echo -e "${RED}Directory not found: $1${RESET}"
        exit 1
    }

    local NAME=$(session_name_from_path "$PROJECT_DIR")
    local PORT=$(next_bridge_port)

    # Check if already registered
    local existing=$(curl -s "http://localhost:$ROUTER_PORT/sessions/$NAME" 2>/dev/null)
    if echo "$existing" | grep -q '"name"' 2>/dev/null; then
        echo -e "${YELLOW}Session '$NAME' already exists.${RESET}"
        return 1
    fi

    # Start Claude session with bridge in tmux
    echo -e "${GREEN}Starting session '$NAME' (port $PORT)...${RESET}"

    tmux new-session -d -s "omt-$NAME" \
        "cd '$PROJECT_DIR' && \
         BRIDGE_PORT=$PORT \
         ROUTER_URL=http://localhost:$ROUTER_PORT \
         SESSION_NAME=$NAME \
         claude --plugin-dir '$PLUGIN_DIR' \
           --dangerously-skip-permissions \
           --dangerously-load-development-channels server:omt-bridge; \
         echo 'Session ended. Press any key...'; read -n1"

    # Wait for bridge to be ready
    local retries=0
    while ! curl -s "http://localhost:$PORT/health" > /dev/null 2>&1; do
        sleep 0.5
        retries=$((retries + 1))
        if [ $retries -gt 30 ]; then
            echo -e "${RED}Bridge failed to start for '$NAME'. Check: tmux a -t omt-$NAME${RESET}"
            return 1
        fi
    done

    # Register with router (creates the Telegram topic)
    local result=$(curl -s -X POST "http://localhost:$ROUTER_PORT/sessions" \
        -H "Content-Type: application/json" \
        -d "{\"name\": \"$NAME\", \"path\": \"$PROJECT_DIR\", \"bridgePort\": $PORT}")

    if echo "$result" | grep -q '"error"' 2>/dev/null; then
        echo -e "${RED}Registration failed: $(echo "$result" | grep -o '"error":"[^"]*"')${RESET}"
        return 1
    fi

    echo -e "${GREEN}${BOLD}Session '$NAME' started.${RESET}"
    echo -e "  ${DIM}Project:${RESET} $PROJECT_DIR"
    echo -e "  ${DIM}Bridge:${RESET}  http://localhost:$PORT"
    echo -e "  ${DIM}Attach:${RESET}  omt hub attach $NAME"
    echo -e "  ${DIM}Talk to it in its Telegram topic.${RESET}"
}

hub_remove() {
    local NAME="$1"
    if [ -z "$NAME" ]; then
        echo -e "${RED}Usage: omt hub remove <session-name>${RESET}"
        exit 1
    fi

    require_router

    # Unregister from router (closes Telegram topic)
    curl -s -X DELETE "http://localhost:$ROUTER_PORT/sessions/$NAME" > /dev/null 2>&1

    # Kill tmux session
    if tmux has-session -t "omt-$NAME" 2>/dev/null; then
        tmux kill-session -t "omt-$NAME"
    fi

    echo -e "${GREEN}Stopped: $NAME${RESET}"
}

hub_list() {
    require_router

    local sessions=$(curl -s "http://localhost:$ROUTER_PORT/sessions" 2>/dev/null)

    if [ -z "$sessions" ] || [ "$sessions" = "{}" ]; then
        echo -e "${DIM}No active sessions. Add one with: omt hub add <dir>${RESET}"
        return
    fi

    echo -e "${BOLD}Active sessions:${RESET}"
    echo ""
    echo "$sessions" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for name, info in data.items():
    print(f'  \033[32m\033[1m{name}\033[0m')
    print(f'    Path:   {info[\"path\"]}')
    print(f'    Bridge: http://localhost:{info[\"bridgePort\"]}')
    print(f'    Thread: {info[\"threadId\"]}')
    print(f'    Since:  {info[\"startedAt\"]}')
    print()
" 2>/dev/null || echo "$sessions" | python3 -m json.tool
}

hub_status() {
    echo -e "${BOLD}Oh My Team Hub${RESET}"
    echo ""

    # Router status
    local health=$(curl -s "http://localhost:$ROUTER_PORT/health" 2>/dev/null)
    if [ -n "$health" ]; then
        local platform=$(echo "$health" | python3 -c "import json,sys; print(json.load(sys.stdin).get('platform','?'))" 2>/dev/null)
        local count=$(echo "$health" | python3 -c "import json,sys; print(json.load(sys.stdin).get('sessions',0))" 2>/dev/null)
        echo -e "  Router:   ${GREEN}running${RESET} (${platform}, ${count} sessions)"
    else
        echo -e "  Router:   ${RED}stopped${RESET}"
    fi

    # Hub session status
    if tmux has-session -t "omt-hub" 2>/dev/null; then
        echo -e "  Hub:      ${GREEN}running${RESET}"
    else
        echo -e "  Hub:      ${RED}stopped${RESET}"
    fi

    echo ""
    hub_list 2>/dev/null
}

hub_attach() {
    local NAME="${1:-hub}"
    if [ "$NAME" = "hub" ]; then
        tmux has-session -t "omt-hub" 2>/dev/null || { echo -e "${RED}Hub not running.${RESET}"; exit 1; }
        tmux attach-session -t "omt-hub"
    elif [ "$NAME" = "router" ]; then
        tmux has-session -t "omt-router" 2>/dev/null || { echo -e "${RED}Router not running.${RESET}"; exit 1; }
        tmux attach-session -t "omt-router"
    else
        tmux has-session -t "omt-$NAME" 2>/dev/null || { echo -e "${RED}Session '$NAME' not found.${RESET}"; hub_list; exit 1; }
        tmux attach-session -t "omt-$NAME"
    fi
}

hub_stop() {
    echo -e "${YELLOW}Stopping all sessions...${RESET}"

    # Stop all project sessions
    local sessions=$(tmux list-sessions 2>/dev/null | grep "^omt-" | grep -v "omt-hub" | grep -v "omt-router" | cut -d: -f1)
    if [ -n "$sessions" ]; then
        while IFS= read -r s; do
            local name="${s#omt-}"
            curl -s -X DELETE "http://localhost:$ROUTER_PORT/sessions/$name" > /dev/null 2>&1
            tmux kill-session -t "$s" 2>/dev/null
            echo -e "  ${GREEN}Stopped: ${s#omt-}${RESET}"
        done <<< "$sessions"
    fi

    # Stop hub
    if tmux has-session -t "omt-hub" 2>/dev/null; then
        tmux kill-session -t "omt-hub"
        echo -e "  ${GREEN}Stopped: hub${RESET}"
    fi

    # Stop router
    if tmux has-session -t "omt-router" 2>/dev/null; then
        tmux kill-session -t "omt-router"
        echo -e "  ${GREEN}Stopped: router${RESET}"
    fi

    echo -e "${GREEN}${BOLD}Hub shut down.${RESET}"
}

hub_logs() {
    if [ -f "$OMT_DIR/router.log" ]; then
        tail -50 "$OMT_DIR/router.log"
    else
        echo -e "${DIM}No logs found.${RESET}"
    fi
}

hub_cmd() {
    case "${1:-status}" in
        init)       shift; hub_init "$@" ;;
        start)      hub_start ;;
        add)        shift; hub_add "$@" ;;
        remove|rm)  shift; hub_remove "$@" ;;
        list|ls)    hub_list ;;
        status)     hub_status ;;
        attach|a)   shift; hub_attach "$@" ;;
        stop)       hub_stop ;;
        logs)       hub_logs ;;
        *)          echo -e "${RED}Unknown hub command: $1${RESET}"; echo "Run: omt help"; exit 1 ;;
    esac
}

# ── Main router ─────────────────────────────────────────────────────────

if [ "$1" = "hub" ]; then
    shift
    hub_cmd "$@"
    exit $?
fi

if [ "$1" = "help" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    echo "omt — Oh My Team CLI"
    echo ""
    echo "Interactive session:"
    echo "  omt                              Start Oh My Team"
    echo "  omt -d                           Start with auto-approve"
    echo "  omt -c                           Continue last session"
    echo ""
    echo "Hub (remote multi-project management):"
    echo "  omt hub init --telegram <token> --chat-id <id>  Configure"
    echo "  omt hub start                    Start router + hub session"
    echo "  omt hub add <dir>                Add a project session"
    echo "  omt hub remove <name>            Stop a project session"
    echo "  omt hub list                     List active sessions"
    echo "  omt hub status                   Overview"
    echo "  omt hub attach [name]            Attach to hub or session"
    echo "  omt hub stop                     Stop everything"
    echo "  omt hub logs                     View router logs"
    exit 0
fi

# ── Interactive session ─────────────────────────────────────────────────

# Expand shortcuts
ARGS=()
for arg in "$@"; do
    case "$arg" in
        -d|--danger) ARGS+=("--dangerously-skip-permissions") ;;
        *)           ARGS+=("$arg") ;;
    esac
done

# If already inside tmux, just run claude directly
if [ -n "$TMUX" ]; then
    exec claude --plugin-dir "$PLUGIN_DIR" "${ARGS[@]}"
fi

# If tmux is available, launch claude inside a new tmux session
if command -v tmux &>/dev/null; then
    SESSION_NAME="omt-$$"
    INNER_CMD="claude --plugin-dir '$PLUGIN_DIR'"
    for a in "${ARGS[@]}"; do
        INNER_CMD="$INNER_CMD '$a'"
    done
    exec tmux new-session -s "$SESSION_NAME" "$INNER_CMD; echo 'Press any key to exit...'; read -n1"
else
    exec claude --plugin-dir "$PLUGIN_DIR" "${ARGS[@]}"
fi
