#!/bin/bash
# omt — Oh My Team CLI
# Single entry point for interactive sessions and hub management
#
# Usage:
#   omt                         Start interactive session (in tmux)
#   omt -d                      Start with auto-approve (danger mode)
#   omt hub init --telegram <token> --chat-id <id>  Configure hub
#   omt hub start               Start router + hub session
#   omt hub add <dir>           Start a project session with bridge
#   omt hub remove <name>       Stop a project session
#   omt hub list                List active sessions
#   omt hub status              Overview
#   omt hub stop                Stop everything

# Colors
CYAN='\033[36m'; GREEN='\033[32m'; YELLOW='\033[33m'; RED='\033[31m'
BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

# Resolve plugin directory
if [ -d "$HOME/.oh-my-team/agents" ]; then
    PLUGIN_DIR="$HOME/.oh-my-team"
elif [ -d "$(dirname "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")")/agents" ]; then
    PLUGIN_DIR="$(dirname "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")")"
else
    echo -e "${RED}Error: Oh My Team plugin not found.${RESET}"
    echo "Run: npm i -g oh-my-team"
    exit 1
fi

OMT_DIR="$HOME/.oh-my-team"
CHANNEL_DIR="$PLUGIN_DIR/channel"
CONFIG_PATH="$OMT_DIR/hub-config.json"
ROUTER_PORT="${ROUTER_PORT:-8800}"
NEXT_BRIDGE_PORT_FILE="$OMT_DIR/.next-bridge-port"

# ── Utility functions ───────────────────────────────────────────────────

session_name_from_path() {
    basename "$1" | tr './ ' '-'
}

next_bridge_port() {
    if [ -f "$NEXT_BRIDGE_PORT_FILE" ]; then
        local port=$(cat "$NEXT_BRIDGE_PORT_FILE")
        echo $((port + 1)) > "$NEXT_BRIDGE_PORT_FILE"
        echo "$port"
    else
        mkdir -p "$OMT_DIR"
        echo "8802" > "$NEXT_BRIDGE_PORT_FILE"
        echo "8801"
    fi
}

require_bun() {
    if ! command -v bun &>/dev/null; then
        echo -e "${RED}Error: Bun is required for hub features.${RESET}"
        echo "Install: curl -fsSL https://bun.sh/install | bash"
        exit 1
    fi
}

require_config() {
    if [ ! -f "$CONFIG_PATH" ]; then
        echo -e "${RED}Hub not configured. Run: omt hub init${RESET}"
        exit 1
    fi
}

get_platform() {
    python3 -c "import json; print(json.load(open('$CONFIG_PATH'))['platform'])" 2>/dev/null || echo "unknown"
}

require_router() {
    if ! curl -s "http://localhost:$ROUTER_PORT/health" > /dev/null 2>&1; then
        echo -e "${RED}Router not running. Run: omt hub start${RESET}"
        exit 1
    fi
}

# ── Hub commands ────────────────────────────────────────────────────────

hub_init() {
    local PLATFORM="" TOKEN="" CHAT_ID="" APP_TOKEN=""

    # Parse flags if provided (non-interactive mode for LLM agents)
    while [ $# -gt 0 ]; do
        case "$1" in
            --telegram)   PLATFORM="telegram"; shift ;;
            --discord)    PLATFORM="discord"; shift ;;
            --slack)      PLATFORM="slack"; shift ;;
            --token)      TOKEN="$2"; shift 2 ;;
            --app-token)  APP_TOKEN="$2"; shift 2 ;;
            --chat-id)    CHAT_ID="$2"; shift 2 ;;
            --channel-id) CHAT_ID="$2"; shift 2 ;;
            *)            shift ;;
        esac
    done

    mkdir -p "$OMT_DIR"

    # If no flags → run the modern interactive flow (arrow keys, masked input, spinners)
    if [ -z "$PLATFORM" ]; then
        local INIT_SCRIPT="$PLUGIN_DIR/bin/hub-init.mjs"
        if [ -f "$INIT_SCRIPT" ] && command -v node &>/dev/null; then
            node "$INIT_SCRIPT" "$OMT_DIR"
            return $?
        fi
        # Fallback: if Node isn't available, use the classic numbered-prompt flow below
        echo -e "  ${BOLD}Step 1:${RESET} Choose your messaging platform"
        echo ""
        echo -e "    ${GREEN}1)${RESET} Telegram  ${DIM}(Forum Topics for per-project threads)${RESET}"
        echo -e "    ${GREEN}2)${RESET} Slack     ${DIM}(threads in a channel via Socket Mode)${RESET}"
        echo -e "    ${DIM}3) Discord   (coming soon)${RESET}"
        echo ""
        read -p "  Choose [1]: " choice
        choice=${choice:-1}
        case "$choice" in
            1) PLATFORM="telegram" ;;
            2) PLATFORM="slack" ;;
            3) echo -e "\n  ${YELLOW}Discord adapter not yet implemented.${RESET}"; exit 1 ;;
            *) echo -e "\n  ${RED}Invalid choice.${RESET}"; exit 1 ;;
        esac
    fi

    if [ "$PLATFORM" = "telegram" ]; then
        # Step 2: Bot token
        if [ -z "$TOKEN" ]; then
            echo ""
            echo -e "  ${BOLD}Step 2:${RESET} Create a Telegram bot"
            echo ""
            echo -e "    1. Open Telegram and search for ${CYAN}@BotFather${RESET}"
            echo -e "    2. Send ${CYAN}/newbot${RESET}"
            echo -e "    3. Give it a name (e.g., \"My Dev Team\")"
            echo -e "    4. Give it a username (e.g., \"mydevteam_bot\")"
            echo -e "    5. Copy the token BotFather gives you"
            echo ""
            echo -e "    ${YELLOW}Important:${RESET} In BotFather, also do:"
            echo -e "    6. Send ${CYAN}/mybots${RESET} → select your bot"
            echo -e "    7. Bot Settings → ${BOLD}Group Privacy → Turn OFF${RESET}"
            echo -e "       (bot must read all group messages, not just commands)"
            echo ""
            read -p "  Paste your bot token: " TOKEN
            if [ -z "$TOKEN" ]; then
                echo -e "  ${RED}Token is required.${RESET}"
                exit 1
            fi
        fi

        # Verify token
        echo -e "  ${DIM}Verifying bot token...${RESET}"
        local bot_info=$(curl -s "https://api.telegram.org/bot${TOKEN}/getMe")
        if echo "$bot_info" | grep -q '"ok":true'; then
            local bot_name=$(echo "$bot_info" | python3 -c "import json,sys; print(json.load(sys.stdin)['result']['username'])" 2>/dev/null || echo "your bot")
            echo -e "  ${GREEN}Connected to @${bot_name}${RESET}"
        else
            echo -e "  ${RED}Invalid token. Check and try again.${RESET}"
            exit 1
        fi

        # Step 3: Create group
        if [ -z "$CHAT_ID" ]; then
            echo ""
            echo -e "  ${BOLD}Step 3:${RESET} Create a Telegram group"
            echo ""
            echo -e "    1. Create a new group in Telegram (name it e.g., \"Oh My Team Hub\")"
            echo -e "    2. Add ${CYAN}@${bot_name}${RESET} to the group"
            echo -e "    3. Make the bot ${BOLD}admin${RESET} (Group Settings → Administrators → Add)"
            echo -e "    4. Enable ${BOLD}Topics${RESET} (Group Settings → Topics → ON)"
            echo -e "    5. Send any message in the group"
            echo ""
            read -p "  Done? Press Enter, then I'll detect the chat ID... " _

            echo -e "  ${DIM}Looking for the group...${RESET}"
            local updates=$(curl -s "https://api.telegram.org/bot${TOKEN}/getUpdates")
            CHAT_ID=$(echo "$updates" | python3 -c "
import json, sys
data = json.load(sys.stdin)
if data.get('ok') and data.get('result'):
    for update in reversed(data['result']):
        msg = update.get('message', {})
        chat = msg.get('chat', {})
        if chat.get('type') in ('group', 'supergroup'):
            print(chat['id'])
            sys.exit(0)
print('')
" 2>/dev/null)

            if [ -z "$CHAT_ID" ]; then
                echo -e "  ${YELLOW}Couldn't auto-detect. Let me try another way...${RESET}"
                echo ""
                echo -e "    Open this URL in your browser:"
                echo -e "    ${CYAN}https://api.telegram.org/bot${TOKEN}/getUpdates${RESET}"
                echo ""
                echo -e "    Look for: ${BOLD}\"chat\":{\"id\":-100XXXXXXXXXX}${RESET}"
                echo ""
                read -p "  Paste the chat ID (starts with -100): " CHAT_ID
                if [ -z "$CHAT_ID" ]; then
                    echo -e "  ${RED}Chat ID is required.${RESET}"
                    exit 1
                fi
            else
                echo -e "  ${GREEN}Found group: ${CHAT_ID}${RESET}"
            fi
        fi

        # Verify group access
        echo -e "  ${DIM}Verifying group access...${RESET}"
        local chat_info=$(curl -s "https://api.telegram.org/bot${TOKEN}/getChat?chat_id=${CHAT_ID}")
        if echo "$chat_info" | grep -q '"ok":true'; then
            local group_name=$(echo "$chat_info" | python3 -c "import json,sys; print(json.load(sys.stdin)['result'].get('title','Group'))" 2>/dev/null || echo "Group")
            echo -e "  ${GREEN}Connected to \"${group_name}\"${RESET}"
        else
            echo -e "  ${RED}Cannot access group. Make sure the bot is added and is admin.${RESET}"
            exit 1
        fi

        # Save config
        cat > "$CONFIG_PATH" << EOF
{
  "platform": "telegram",
  "credentials": {
    "botToken": "$TOKEN",
    "chatId": "$CHAT_ID"
  }
}
EOF

        echo ""
        echo -e "  ${GREEN}${BOLD}Hub configured!${RESET}"
        echo ""
        echo -e "  ${DIM}Platform:${RESET} Telegram"
        echo -e "  ${DIM}Bot:${RESET}      @${bot_name}"
        echo -e "  ${DIM}Group:${RESET}    ${group_name} (${CHAT_ID})"
        echo ""
        echo -e "  Next: ${CYAN}omt hub start${RESET}"
        echo ""
    fi

    if [ "$PLATFORM" = "slack" ]; then
        # Generate one-click manifest URL
        local create_url=$(python3 -c "
import urllib.parse, json
m = {
    'display_information': {
        'name': 'Oh My Team',
        'description': 'Multi-agent orchestration hub for Claude Code'
    },
    'features': {
        'bot_user': {'display_name': 'Oh My Team', 'always_online': True}
    },
    'oauth_config': {
        'scopes': {
            'bot': ['chat:write','channels:history','channels:read','groups:history','groups:read','pins:write','users:read']
        }
    },
    'settings': {
        'event_subscriptions': {'bot_events': ['message.channels','message.groups']},
        'socket_mode_enabled': True,
        'org_deploy_enabled': False,
        'token_rotation_enabled': False
    }
}
print('https://api.slack.com/apps?new_app=1&manifest_json=' + urllib.parse.quote(json.dumps(m)))
" 2>/dev/null)

        # Step 2: Create Slack App
        echo ""
        echo -e "  ${BOLD}Step 2:${RESET} Create a Slack App"
        echo ""
        if [ -n "$create_url" ]; then
            echo -e "    ${GREEN}One-click setup — open this URL:${RESET}"
            echo ""
            echo -e "    ${CYAN}${create_url}${RESET}"
            echo ""
            echo -e "    ${DIM}This pre-configures Socket Mode, scopes, and events.${RESET}"
        else
            echo -e "    Go to ${CYAN}https://api.slack.com/apps${RESET} → Create New App → From manifest"
            echo -e "    Paste the manifest from: ${CYAN}$PLUGIN_DIR/channel/slack-manifest.yml${RESET}"
        fi
        echo ""
        echo -e "    After creating the app:"
        echo -e "    a) Generate an ${BOLD}App-Level Token${RESET}:"
        echo -e "       Basic Information → App-Level Tokens → Generate Token"
        echo -e "       Name: ${CYAN}omt${RESET}, Scope: ${CYAN}connections:write${RESET}"
        echo -e "    b) ${BOLD}Install${RESET} the app to your workspace:"
        echo -e "       OAuth & Permissions → Install to Workspace"
        echo ""
        read -p "  Done? Press Enter to continue... " _

        # Step 3: App Token
        if [ -z "$APP_TOKEN" ]; then
            echo ""
            echo -e "  ${BOLD}Step 3:${RESET} App-Level Token"
            echo ""
            echo -e "    Find it in: Settings → Basic Information → App-Level Tokens"
            echo ""
            read -p "  Paste your App Token (xapp-...): " APP_TOKEN
            if [ -z "$APP_TOKEN" ] || [[ ! "$APP_TOKEN" =~ ^xapp- ]]; then
                echo -e "  ${RED}Invalid App Token. Must start with xapp-${RESET}"
                exit 1
            fi
        fi

        # Verify app token
        echo -e "  ${DIM}Verifying App Token...${RESET}"
        local app_check=$(curl -s -H "Authorization: Bearer $APP_TOKEN" -X POST "https://slack.com/api/apps.connections.open")
        if echo "$app_check" | grep -q '"ok":true'; then
            echo -e "  ${GREEN}App Token valid${RESET}"
        else
            local app_err=$(echo "$app_check" | python3 -c "import json,sys; print(json.load(sys.stdin).get('error','unknown'))" 2>/dev/null || echo "unknown")
            echo -e "  ${RED}Invalid App Token: ${app_err}${RESET}"
            echo -e "  ${DIM}Make sure Socket Mode is enabled and the token has connections:write scope.${RESET}"
            exit 1
        fi

        # Step 4: Bot Token
        if [ -z "$TOKEN" ]; then
            echo ""
            echo -e "  ${BOLD}Step 4:${RESET} Bot Token"
            echo ""
            echo -e "    Find it in: OAuth & Permissions → Bot User OAuth Token"
            echo ""
            read -p "  Paste your Bot Token (xoxb-...): " TOKEN
            if [ -z "$TOKEN" ] || [[ ! "$TOKEN" =~ ^xoxb- ]]; then
                echo -e "  ${RED}Invalid Bot Token. Must start with xoxb-${RESET}"
                exit 1
            fi
        fi

        # Verify bot token
        echo -e "  ${DIM}Verifying Bot Token...${RESET}"
        local bot_info=$(curl -s -H "Authorization: Bearer $TOKEN" "https://slack.com/api/auth.test")
        if echo "$bot_info" | grep -q '"ok":true'; then
            local bot_name=$(echo "$bot_info" | python3 -c "import json,sys; print(json.load(sys.stdin).get('user','bot'))" 2>/dev/null || echo "bot")
            echo -e "  ${GREEN}Connected as @${bot_name}${RESET}"
        else
            local bot_err=$(echo "$bot_info" | python3 -c "import json,sys; print(json.load(sys.stdin).get('error','unknown'))" 2>/dev/null || echo "unknown")
            echo -e "  ${RED}Invalid Bot Token: ${bot_err}${RESET}"
            exit 1
        fi

        # Step 5: Channel
        if [ -z "$CHAT_ID" ]; then
            echo ""
            echo -e "  ${BOLD}Step 5:${RESET} Channel setup"
            echo ""
            echo -e "    1. Create a channel (e.g., ${CYAN}#omt${RESET}) or use an existing one"
            echo -e "    2. Invite the bot: type ${CYAN}/invite @${bot_name}${RESET} in the channel"
            echo -e "    3. Get the Channel ID:"
            echo -e "       Click the channel name → scroll to the bottom of the About panel"
            echo -e "       ${DIM}(or copy from the channel URL: .../C0123ABC456)${RESET}"
            echo ""
            read -p "  Paste Channel ID (starts with C): " CHAT_ID
            if [ -z "$CHAT_ID" ] || [[ ! "$CHAT_ID" =~ ^C ]]; then
                echo -e "  ${RED}Invalid Channel ID. Must start with C${RESET}"
                exit 1
            fi
        fi

        # Verify channel access
        echo -e "  ${DIM}Verifying channel access...${RESET}"
        local chan_info=$(curl -s -H "Authorization: Bearer $TOKEN" "https://slack.com/api/conversations.info?channel=$CHAT_ID")
        if echo "$chan_info" | grep -q '"ok":true'; then
            local chan_name=$(echo "$chan_info" | python3 -c "import json,sys; print(json.load(sys.stdin)['channel'].get('name','channel'))" 2>/dev/null || echo "channel")
            echo -e "  ${GREEN}Connected to #${chan_name}${RESET}"
        else
            local chan_err=$(echo "$chan_info" | python3 -c "import json,sys; print(json.load(sys.stdin).get('error','unknown'))" 2>/dev/null || echo "unknown")
            echo -e "  ${RED}Cannot access channel: ${chan_err}${RESET}"
            echo -e "  ${DIM}Make sure the bot is invited to the channel (/invite @${bot_name}).${RESET}"
            exit 1
        fi

        # Save config
        cat > "$CONFIG_PATH" << EOF
{
  "platform": "slack",
  "credentials": {
    "botToken": "$TOKEN",
    "appToken": "$APP_TOKEN",
    "channelId": "$CHAT_ID"
  }
}
EOF

        echo ""
        echo -e "  ${GREEN}${BOLD}Hub configured!${RESET}"
        echo ""
        echo -e "  ${DIM}Platform:${RESET} Slack"
        echo -e "  ${DIM}Bot:${RESET}      @${bot_name}"
        echo -e "  ${DIM}Channel:${RESET}  #${chan_name} (${CHAT_ID})"
        echo ""
        echo -e "  Next: ${CYAN}omt hub start${RESET}"
        echo ""
    fi
}

hub_restore_sessions() {
    local REGISTRY_FILE="$OMT_DIR/hub-registry.json"
    if [ ! -f "$REGISTRY_FILE" ]; then
        return
    fi

    # Read session names, paths, and threadIds from registry (excluding "hub")
    local restore_list=$(python3 -c "
import json, sys, os
try:
    with open('$REGISTRY_FILE') as f:
        data = json.load(f)
    for name, info in data.get('sessions', {}).items():
        if name == 'hub':
            continue
        path = info.get('path', '')
        if path and os.path.isdir(path):
            print(f'{name}\t{path}')
        else:
            print(f'STALE: {name} ({path})', file=sys.stderr)
except Exception as e:
    print(f'Error reading registry: {e}', file=sys.stderr)
" 2>/dev/null)

    if [ -z "$restore_list" ]; then
        return
    fi

    echo ""
    echo -e "${CYAN}Restoring previous sessions...${RESET}"

    while IFS=$'\t' read -r name proj_path; do
        echo -e "  ${DIM}Restoring $name ($proj_path)...${RESET}"

        # Allocate a new bridge port (old one might be taken after restart)
        local PORT=$(cat "$NEXT_BRIDGE_PORT_FILE" 2>/dev/null || echo "8802")
        echo "$((PORT + 1))" > "$NEXT_BRIDGE_PORT_FILE"

        # Ensure bridge MCP is registered for this project
        local BRIDGE_TS="$PLUGIN_DIR/channel/bridge.ts"
        local PROJECT_MCP="$proj_path/.mcp.json"
        if [ ! -f "$PROJECT_MCP" ] || ! grep -q "omt-bridge" "$PROJECT_MCP" 2>/dev/null; then
            python3 -c "
import json, os
path = '$PROJECT_MCP'
cfg = {}
if os.path.exists(path):
    try:
        with open(path) as f: cfg = json.load(f)
    except: pass
cfg.setdefault('mcpServers', {})['omt-bridge'] = {
    'command': 'bun',
    'args': ['run', '$BRIDGE_TS']
}
with open(path, 'w') as f: json.dump(cfg, f, indent=2)
" 2>/dev/null
        fi

        # Write session env for hooks
        cat > "$proj_path/.omt-env" << ENVEOF
ROUTER_URL=http://localhost:$ROUTER_PORT
SESSION_NAME=$name
ENVEOF

        # Start Claude session with --continue to resume conversation
        tmux new-session -d -s "omt-$name" \
            "cd '$proj_path' && \
             BRIDGE_PORT=$PORT \
             ROUTER_URL=http://localhost:$ROUTER_PORT \
             SESSION_NAME=$name \
             OMT_PLUGIN_DIR='$PLUGIN_DIR' \
             claude --plugin-dir '$PLUGIN_DIR' \
               --agent sisyphus \
               --dangerously-skip-permissions \
               --dangerously-load-development-channels server:omt-bridge \
               --continue; \
             echo 'Session ended. Press any key...'; read -n1"

        # Auto-accept trust/channel prompts
        sleep 2
        tmux send-keys -t "omt-$name" Enter 2>/dev/null
        sleep 1
        tmux send-keys -t "omt-$name" Enter 2>/dev/null
        sleep 1
        tmux send-keys -t "omt-$name" Enter 2>/dev/null

        # Wait for bridge to be ready, then re-register with router
        (
            local retries=0
            while ! curl -s "http://localhost:$PORT/health" > /dev/null 2>&1; do
                sleep 1
                retries=$((retries + 1))
                if [ $retries -gt 60 ]; then
                    echo -e "  ${RED}Failed to restore '$name' — bridge timeout.${RESET}" >&2
                    break
                fi
                # Extra Enter in case of lingering prompts
                [ $((retries % 10)) -eq 0 ] && tmux send-keys -t "omt-$name" Enter 2>/dev/null
            done

            if curl -s "http://localhost:$PORT/health" > /dev/null 2>&1; then
                # Re-register with router (reuses existing threadId from registry)
                local result=$(curl -s -X POST "http://localhost:$ROUTER_PORT/sessions" \
                    -H "Content-Type: application/json" \
                    -d "{\"name\": \"$name\", \"path\": \"$proj_path\", \"bridgePort\": $PORT}")
                if echo "$result" | grep -q '"error"' 2>/dev/null; then
                    echo -e "  ${RED}Registration failed for '$name'.${RESET}" >&2
                else
                    echo -e "  ${GREEN}Restored: $name (port $PORT)${RESET}"
                fi
            fi
        ) &
    done <<< "$restore_list"

    # Wait for all background restore jobs to finish
    wait

    # Clean stale entries from registry (paths that no longer exist)
    python3 -c "
import json, os
path = '$OMT_DIR/hub-registry.json'
try:
    with open(path) as f: data = json.load(f)
    stale = [n for n, info in data.get('sessions', {}).items()
             if n != 'hub' and not os.path.isdir(info.get('path', ''))]
    if stale:
        for n in stale: del data['sessions'][n]
        with open(path, 'w') as f: json.dump(data, f, indent=2)
except: pass
" 2>/dev/null
}

hub_start() {
    local CONTINUE_FLAG=""
    if [ "$1" = "-c" ] || [ "$1" = "--continue" ]; then
        CONTINUE_FLAG="--continue"
        shift
    fi

    # Auto-continue: if the hub was previously initialized, resume the
    # conversation instead of starting fresh (unless user passed -c explicitly).
    local HUB_INIT_FLAG="$OMT_DIR/.hub-initialized"
    if [ -z "$CONTINUE_FLAG" ] && [ -f "$HUB_INIT_FLAG" ]; then
        CONTINUE_FLAG="--continue"
        echo -e "${DIM}Resuming previous hub session...${RESET}"
    fi

    require_bun
    require_config

    # Install channel deps if needed
    if [ ! -d "$CHANNEL_DIR/node_modules" ]; then
        echo -e "${YELLOW}Installing channel dependencies...${RESET}"
        (cd "$CHANNEL_DIR" && bun install --no-summary 2>&1)
    fi

    # Start the router
    if tmux has-session -t "omt-router" 2>/dev/null; then
        echo -e "${YELLOW}Router already running.${RESET}"
    else
        echo -e "${GREEN}Starting router on port $ROUTER_PORT...${RESET}"
        tmux new-session -d -s "omt-router" \
            "cd '$CHANNEL_DIR' && OMT_HUB_DIR='$OMT_DIR' ROUTER_PORT=$ROUTER_PORT bun run router.ts 2>&1 | tee '$OMT_DIR/router.log'; echo 'Router stopped. Press any key...'; read -n1"

        # Wait for router to be ready
        local retries=0
        while ! curl -s "http://localhost:$ROUTER_PORT/health" > /dev/null 2>&1; do
            sleep 0.5
            retries=$((retries + 1))
            if [ $retries -gt 20 ]; then
                echo -e "${RED}Router failed to start. Check: omt hub logs${RESET}"
                exit 1
            fi
        done
        echo -e "${GREEN}Router ready.${RESET}"
    fi

    # Start the hub Claude session with a bridge connected to General topic
    local HUB_BRIDGE_PORT=8801
    if tmux has-session -t "omt-hub" 2>/dev/null; then
        echo -e "${YELLOW}Hub session already running.${RESET}"
    else
        echo -e "${GREEN}Starting hub session (bridge on port $HUB_BRIDGE_PORT)...${RESET}"

        # Reset next bridge port to start after hub's port
        echo "8802" > "$NEXT_BRIDGE_PORT_FILE"

        # Ensure omt-bridge MCP server is registered in BOTH locations
        # Plugin .mcp.json: read by --plugin-dir
        # User ~/.mcp.json: read by --dangerously-load-development-channels
        local BRIDGE_TS="$PLUGIN_DIR/channel/bridge.ts"
        local BRIDGE_MCP='{"mcpServers":{"omt-bridge":{"command":"bun","args":["run","'"$BRIDGE_TS"'"]}}}'

        # Write to plugin .mcp.json
        echo "$BRIDGE_MCP" | python3 -m json.tool > "$PLUGIN_DIR/.mcp.json" 2>/dev/null

        # Write to user-level ~/.mcp.json (merge, don't overwrite other servers)
        python3 -c "
import json, os
path = os.path.expanduser('~/.mcp.json')
cfg = {}
if os.path.exists(path):
    try:
        with open(path) as f: cfg = json.load(f)
    except: pass
cfg.setdefault('mcpServers', {})['omt-bridge'] = {
    'command': 'bun',
    'args': ['run', '$BRIDGE_TS']
}
with open(path, 'w') as f: json.dump(cfg, f, indent=2)
" 2>/dev/null

        # Clear stale agent overrides but preserve hooks config
        if [ -f "$PLUGIN_DIR/settings.json" ]; then
            python3 -c "
import json
path = '$PLUGIN_DIR/settings.json'
with open(path) as f: cfg = json.load(f)
cfg.pop('agent', None)
with open(path, 'w') as f: json.dump(cfg, f, indent=2)
" 2>/dev/null
        fi

        echo -e "  ${DIM}Bridge MCP registered. Settings cleared.${RESET}"

        # Write session env for hooks (Claude Code doesn't pass custom env vars to hooks)
        cat > "$HOME/.omt-env" << ENVEOF
ROUTER_URL=http://localhost:$ROUTER_PORT
SESSION_NAME=hub
ENVEOF

        echo -e "${GREEN}Starting hub session...${RESET}"

        tmux new-session -d -s "omt-hub" \
            "cd '$HOME' && \
             BRIDGE_PORT=$HUB_BRIDGE_PORT \
             ROUTER_URL=http://localhost:$ROUTER_PORT \
             SESSION_NAME=hub \
             OMT_PLUGIN_DIR='$PLUGIN_DIR' \
             claude --plugin-dir '$PLUGIN_DIR' \
               --agent hub \
               --dangerously-skip-permissions \
               --dangerously-load-development-channels server:omt-bridge \
               $CONTINUE_FLAG; \
             echo 'Hub stopped. Press any key...'; read -n1"

        # Auto-accept trust and channel prompts (no manual interaction needed)
        sleep 3
        tmux send-keys -t omt-hub Enter 2>/dev/null
        sleep 2
        tmux send-keys -t omt-hub Enter 2>/dev/null

        # Wait for bridge to be ready
        echo -e "  ${DIM}Waiting for hub bridge...${RESET}"
        local retries=0
        while ! curl -s "http://localhost:$HUB_BRIDGE_PORT/health" > /dev/null 2>&1; do
            sleep 1
            retries=$((retries + 1))
            if [ $retries -gt 60 ]; then
                echo -e "${YELLOW}Hub bridge not ready yet. You may need to accept prompts:${RESET}"
                echo -e "  ${CYAN}omt hub attach${RESET}  (then Ctrl+B, D to detach)"
                break
            fi
            # Periodically retry auto-accept in case prompts appeared late
            [ $((retries % 10)) -eq 0 ] && tmux send-keys -t omt-hub Enter 2>/dev/null
        done

        # Register hub with the router
        if curl -s "http://localhost:$HUB_BRIDGE_PORT/health" > /dev/null 2>&1; then
            local reg_retries=0
            while [ $reg_retries -lt 5 ]; do
                local reg_result=$(curl -s -X POST "http://localhost:$ROUTER_PORT/sessions" \
                    -H "Content-Type: application/json" \
                    -d "{\"name\": \"hub\", \"path\": \"$HOME\", \"bridgePort\": $HUB_BRIDGE_PORT, \"isHub\": true}")
                echo "$reg_result" | grep -q '"threadId"' 2>/dev/null && break
                reg_retries=$((reg_retries + 1))
                sleep 1
            done
            echo -e "${GREEN}Hub registered.${RESET}"
        fi
    fi

    # Mark hub as initialized so future starts auto-continue
    touch "$HUB_INIT_FLAG"

    local platform=$(get_platform)
    echo ""
    echo -e "${GREEN}${BOLD}Oh My Team Hub is running.${RESET}"
    echo ""
    echo -e "  ${DIM}Router:${RESET}    http://localhost:$ROUTER_PORT"
    echo -e "  ${DIM}Hub:${RESET}       http://localhost:$HUB_BRIDGE_PORT"
    echo -e "  ${DIM}Attach:${RESET}    omt hub attach"
    if [ "$platform" = "slack" ]; then
        echo -e "  ${DIM}Slack:${RESET}     Post a message in the channel"
    else
        echo -e "  ${DIM}Telegram:${RESET}  Send a message in the General topic"
    fi
    echo ""
    echo -e "  Add projects: ${CYAN}omt hub add <project-dir>${RESET}"
    if [ "$platform" = "slack" ]; then
        echo -e "  From Slack: send \"start ~/projects/my-app\" in the channel"
    else
        echo -e "  From Telegram: send \"start ~/projects/my-app\" in General"
    fi

    # ── Restore previous sessions ──────────────────────────────────
    hub_restore_sessions
}

hub_add() {
    local CONTINUE_FLAG=""
    local PROJECT_DIR=""

    # Parse args — support -c flag in any position
    for arg in "$@"; do
        case "$arg" in
            -c|--continue) CONTINUE_FLAG="--continue" ;;
            *)             [ -z "$PROJECT_DIR" ] && PROJECT_DIR="$arg" ;;
        esac
    done

    if [ -z "$PROJECT_DIR" ]; then
        echo -e "${RED}Usage: omt hub add <project-directory> [-c]${RESET}"
        exit 1
    fi

    require_router

    # Resolve to absolute path
    PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
        echo -e "${RED}Directory not found: $1${RESET}"
        exit 1
    }

    local NAME=$(session_name_from_path "$PROJECT_DIR")
    local PORT=$(next_bridge_port)

    # Check if already registered
    local existing=$(curl -s "http://localhost:$ROUTER_PORT/sessions/$NAME" 2>/dev/null)
    if echo "$existing" | grep -q '"name"' 2>/dev/null; then
        echo -e "${YELLOW}Session '$NAME' already exists.${RESET}"
        return 1
    fi

    # Ensure bridge MCP is registered for this project too
    local BRIDGE_TS="$PLUGIN_DIR/channel/bridge.ts"
    local PROJECT_MCP="$PROJECT_DIR/.mcp.json"
    if [ ! -f "$PROJECT_MCP" ] || ! grep -q "omt-bridge" "$PROJECT_MCP" 2>/dev/null; then
        python3 -c "
import json, os
path = '$PROJECT_MCP'
cfg = {}
if os.path.exists(path):
    try:
        with open(path) as f: cfg = json.load(f)
    except: pass
cfg.setdefault('mcpServers', {})['omt-bridge'] = {
    'command': 'bun',
    'args': ['run', '$BRIDGE_TS']
}
with open(path, 'w') as f: json.dump(cfg, f, indent=2)
" 2>/dev/null
    fi

    # Write session env for hooks (Claude Code doesn't pass custom env vars to hooks)
    cat > "$PROJECT_DIR/.omt-env" << ENVEOF
ROUTER_URL=http://localhost:$ROUTER_PORT
SESSION_NAME=$NAME
ENVEOF

    # Start Claude session with bridge in tmux
    # Auto-accept prompts: pipe Enter keystrokes after a delay to handle
    # the workspace trust and development channel warning dialogs
    echo -e "${GREEN}Starting session '$NAME' (port $PORT)...${RESET}"

    tmux new-session -d -s "omt-$NAME" \
        "cd '$PROJECT_DIR' && \
         BRIDGE_PORT=$PORT \
         ROUTER_URL=http://localhost:$ROUTER_PORT \
         SESSION_NAME=$NAME \
         OMT_PLUGIN_DIR='$PLUGIN_DIR' \
         claude --plugin-dir '$PLUGIN_DIR' \
           --agent sisyphus \
           --dangerously-skip-permissions \
           --dangerously-load-development-channels server:omt-bridge \
           $CONTINUE_FLAG; \
         echo 'Session ended. Press any key...'; read -n1"

    # Auto-accept the interactive prompts (trust + channel warning)
    sleep 2
    tmux send-keys -t "omt-$NAME" Enter 2>/dev/null
    sleep 1
    tmux send-keys -t "omt-$NAME" Enter 2>/dev/null
    sleep 1
    tmux send-keys -t "omt-$NAME" Enter 2>/dev/null

    # Wait for bridge to be ready (longer timeout for first-run prompts)
    local retries=0
    while ! curl -s "http://localhost:$PORT/health" > /dev/null 2>&1; do
        sleep 1
        retries=$((retries + 1))
        if [ $retries -gt 45 ]; then
            echo -e "${RED}Bridge failed to start for '$NAME'. Check: tmux a -t omt-$NAME${RESET}"
            return 1
        fi
        # Send extra Enter in case prompts are still pending
        [ $((retries % 5)) -eq 0 ] && tmux send-keys -t "omt-$NAME" Enter 2>/dev/null
    done

    # Register with router (creates a thread/topic for the session)
    local result=$(curl -s -X POST "http://localhost:$ROUTER_PORT/sessions" \
        -H "Content-Type: application/json" \
        -d "{\"name\": \"$NAME\", \"path\": \"$PROJECT_DIR\", \"bridgePort\": $PORT}")

    if echo "$result" | grep -q '"error"' 2>/dev/null; then
        echo -e "${RED}Registration failed: $(echo "$result" | grep -o '"error":"[^"]*"')${RESET}"
        return 1
    fi

    local platform=$(get_platform)
    echo -e "${GREEN}${BOLD}Session '$NAME' started.${RESET}"
    echo -e "  ${DIM}Project:${RESET} $PROJECT_DIR"
    echo -e "  ${DIM}Bridge:${RESET}  http://localhost:$PORT"
    echo -e "  ${DIM}Attach:${RESET}  omt hub attach $NAME"
    if [ "$platform" = "slack" ]; then
        echo -e "  ${DIM}Talk to it in its Slack thread.${RESET}"
    else
        echo -e "  ${DIM}Talk to it in its Telegram topic.${RESET}"
    fi
}

hub_remove() {
    local NAME="$1"
    if [ -z "$NAME" ]; then
        echo -e "${RED}Usage: omt hub remove <session-name>${RESET}"
        exit 1
    fi

    require_router

    # Get session path before removing (for .omt-env cleanup)
    local session_path=$(curl -s "http://localhost:$ROUTER_PORT/sessions/$NAME" 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('path',''))" 2>/dev/null)

    # Unregister from router (closes Telegram topic)
    curl -s -X DELETE "http://localhost:$ROUTER_PORT/sessions/$NAME" > /dev/null 2>&1

    # Kill tmux session
    if tmux has-session -t "omt-$NAME" 2>/dev/null; then
        tmux kill-session -t "omt-$NAME"
    fi

    # Clean up .omt-env
    [ -n "$session_path" ] && rm -f "$session_path/.omt-env" 2>/dev/null

    echo -e "${GREEN}Stopped: $NAME${RESET}"
}

hub_list() {
    require_router

    local sessions=$(curl -s "http://localhost:$ROUTER_PORT/sessions" 2>/dev/null)

    if [ -z "$sessions" ] || [ "$sessions" = "{}" ]; then
        echo -e "${DIM}No active sessions. Add one with: omt hub add <dir>${RESET}"
        return
    fi

    echo -e "${BOLD}Active sessions:${RESET}"
    echo ""
    echo "$sessions" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for name, info in data.items():
    print(f'  \033[32m\033[1m{name}\033[0m')
    print(f'    Path:   {info[\"path\"]}')
    print(f'    Bridge: http://localhost:{info[\"bridgePort\"]}')
    print(f'    Thread: {info[\"threadId\"]}')
    print(f'    Since:  {info[\"startedAt\"]}')
    print()
" 2>/dev/null || echo "$sessions" | python3 -m json.tool
}

hub_status() {
    echo -e "${BOLD}Oh My Team Hub${RESET}"
    echo ""

    # Router status
    local health=$(curl -s "http://localhost:$ROUTER_PORT/health" 2>/dev/null)
    if [ -n "$health" ]; then
        local platform=$(echo "$health" | python3 -c "import json,sys; print(json.load(sys.stdin).get('platform','?'))" 2>/dev/null)
        local count=$(echo "$health" | python3 -c "import json,sys; print(json.load(sys.stdin).get('sessions',0))" 2>/dev/null)
        echo -e "  Router:   ${GREEN}running${RESET} (${platform}, ${count} sessions)"
    else
        echo -e "  Router:   ${RED}stopped${RESET}"
    fi

    # Hub session status
    if tmux has-session -t "omt-hub" 2>/dev/null; then
        echo -e "  Hub:      ${GREEN}running${RESET}"
    else
        echo -e "  Hub:      ${RED}stopped${RESET}"
    fi

    echo ""
    hub_list 2>/dev/null
}

hub_attach() {
    local NAME="${1:-hub}"
    if [ "$NAME" = "hub" ]; then
        tmux has-session -t "omt-hub" 2>/dev/null || { echo -e "${RED}Hub not running.${RESET}"; exit 1; }
        tmux attach-session -t "omt-hub"
    elif [ "$NAME" = "router" ]; then
        tmux has-session -t "omt-router" 2>/dev/null || { echo -e "${RED}Router not running.${RESET}"; exit 1; }
        tmux attach-session -t "omt-router"
    else
        tmux has-session -t "omt-$NAME" 2>/dev/null || { echo -e "${RED}Session '$NAME' not found.${RESET}"; hub_list; exit 1; }
        tmux attach-session -t "omt-$NAME"
    fi
}

hub_stop() {
    local CLEAN=false
    if [ "$1" = "--clean" ] || [ "$1" = "--force" ]; then
        CLEAN=true
    fi

    echo -e "${YELLOW}Stopping all sessions...${RESET}"

    # Stop all project sessions
    local sessions=$(tmux list-sessions 2>/dev/null | grep "^omt-" | grep -v "omt-hub" | grep -v "omt-router" | cut -d: -f1)
    if [ -n "$sessions" ]; then
        while IFS= read -r s; do
            local name="${s#omt-}"
            if [ "$CLEAN" = true ]; then
                # Destructive: close threads and unregister
                local session_path=$(curl -s "http://localhost:$ROUTER_PORT/sessions/$name" 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('path',''))" 2>/dev/null)
                [ -n "$session_path" ] && rm -f "$session_path/.omt-env" 2>/dev/null
                curl -s -X DELETE "http://localhost:$ROUTER_PORT/sessions/$name" > /dev/null 2>&1
            fi
            tmux kill-session -t "$s" 2>/dev/null
            echo -e "  ${GREEN}Stopped: ${s#omt-}${RESET}"
        done <<< "$sessions"
    fi

    # Clean up .omt-env files (stale ports)
    rm -f "$HOME/.omt-env" 2>/dev/null

    # Stop hub
    if tmux has-session -t "omt-hub" 2>/dev/null; then
        tmux kill-session -t "omt-hub"
        echo -e "  ${GREEN}Stopped: hub${RESET}"
    fi

    # Stop router (registry file on disk is preserved unless --clean)
    if tmux has-session -t "omt-router" 2>/dev/null; then
        tmux kill-session -t "omt-router"
        echo -e "  ${GREEN}Stopped: router${RESET}"
    fi

    if [ "$CLEAN" = true ]; then
        rm -f "$OMT_DIR/hub-registry.json" 2>/dev/null
        rm -f "$OMT_DIR/.hub-initialized" 2>/dev/null
        echo -e "${GREEN}${BOLD}Hub shut down and cleaned. Next start will be fresh.${RESET}"
    else
        echo -e "${GREEN}${BOLD}Hub shut down. Sessions preserved — run 'omt hub start' to resume.${RESET}"
    fi
}

hub_logs() {
    if [ -f "$OMT_DIR/router.log" ]; then
        tail -50 "$OMT_DIR/router.log"
    else
        echo -e "${DIM}No logs found.${RESET}"
    fi
}

hub_cmd() {
    case "${1:-status}" in
        init)       shift; hub_init "$@" ;;
        start)      shift; hub_start "$@" ;;
        add)        shift; hub_add "$@" ;;
        remove|rm)  shift; hub_remove "$@" ;;
        list|ls)    hub_list ;;
        status)     hub_status ;;
        attach|a)   shift; hub_attach "$@" ;;
        stop)       shift; hub_stop "$@" ;;
        logs)       hub_logs ;;
        *)          echo -e "${RED}Unknown hub command: $1${RESET}"; echo "Run: omt help"; exit 1 ;;
    esac
}

# ── Main router ─────────────────────────────────────────────────────────

if [ "$1" = "hub" ]; then
    shift
    hub_cmd "$@"
    exit $?
fi

if [ "$1" = "help" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    echo "omt — Oh My Team CLI"
    echo ""
    echo "Interactive session:"
    echo "  omt                              Start Oh My Team"
    echo "  omt -d                           Start with auto-approve"
    echo "  omt -c                           Continue last session"
    echo ""
    echo "Hub (remote multi-project management):"
    echo "  omt hub init                    Configure hub (interactive)"
    echo "  omt hub init --telegram --token <t> --chat-id <id>"
    echo "  omt hub init --slack --token <xoxb> --app-token <xapp> --channel-id <C>"
    echo "  omt hub start [-c]               Start router + hub session (-c to continue)"
    echo "  omt hub add <dir> [-c]           Add a project session (-c to continue)"
    echo "  omt hub remove <name>            Stop a project session"
    echo "  omt hub list                     List active sessions"
    echo "  omt hub status                   Overview"
    echo "  omt hub attach [name]            Attach to hub or session"
    echo "  omt hub stop                     Stop hub (preserves sessions for resume)"
    echo "  omt hub stop --clean             Stop hub and close all threads"
    echo "  omt hub logs                     View router logs"
    exit 0
fi

# ── Interactive session ─────────────────────────────────────────────────

# Expand shortcuts
ARGS=()
for arg in "$@"; do
    case "$arg" in
        -d|--danger) ARGS+=("--dangerously-skip-permissions") ;;
        *)           ARGS+=("$arg") ;;
    esac
done

# If already inside tmux, just run claude directly
if [ -n "$TMUX" ]; then
    exec claude --plugin-dir "$PLUGIN_DIR" --agent sisyphus "${ARGS[@]}"
fi

# If tmux is available, launch claude inside a new tmux session
if command -v tmux &>/dev/null; then
    SESSION_NAME="omt-$$"
    INNER_CMD="claude --plugin-dir '$PLUGIN_DIR' --agent sisyphus"
    for a in "${ARGS[@]}"; do
        INNER_CMD="$INNER_CMD '$a'"
    done
    exec tmux new-session -s "$SESSION_NAME" "$INNER_CMD; echo 'Press any key to exit...'; read -n1"
else
    exec claude --plugin-dir "$PLUGIN_DIR" --agent sisyphus "${ARGS[@]}"
fi
