{
  "description": "Oh My Team — Live status hooks for hub sessions",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .sisyphus/plans .sisyphus/drafts .sisyphus/notepads 2>/dev/null; echo '{}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash|Grep|Glob|Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"${CLAUDE_PLUGIN_ROOT}/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash|Grep|Glob|Agent|TaskCreate|TaskUpdate|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"${CLAUDE_PLUGIN_ROOT}/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"${CLAUDE_PLUGIN_ROOT}/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"${CLAUDE_PLUGIN_ROOT}/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"${CLAUDE_PLUGIN_ROOT}/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
