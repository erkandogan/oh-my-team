{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .sisyphus/plans .sisyphus/drafts .sisyphus/notepads 2>/dev/null; echo '{}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "Agent"
        },
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"$OMT_PLUGIN_DIR/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "TaskCreate"
        },
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"$OMT_PLUGIN_DIR/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "TaskUpdate"
        },
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"$OMT_PLUGIN_DIR/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Skill"
        },
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -z \"$ROUTER_URL\" ] && exit 0; bash \"$OMT_PLUGIN_DIR/hooks/status-hook.sh\"'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
