{
  "name": "oh-my-team",
  "version": "2.8.0",
  "description": "Multi-agent orchestration for Claude Code. 12 specialized agents, parallel execution, and a Hub for always-alive sessions controllable from Telegram or Slack.",
  "bin": {
    "omt": "bin/omt"
  },
  "scripts": {
    "build:init": "bun build bin/hub-init.ts --outfile bin/hub-init.mjs --target node",
    "postinstall": "node ./bin/postinstall.js"
  },
  "keywords": [
    "claude-code",
    "claude",
    "ai",
    "multi-agent",
    "orchestration",
    "agent-teams",
    "plugin",
    "claude-code-plugin",
    "tmux",
    "ai-coding"
  ],
  "author": "Erkan DOGAN",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erkandogan/oh-my-team.git"
  },
  "homepage": "https://ohmyteam.cc",
  "bugs": {
    "url": "https://github.com/erkandogan/oh-my-team/issues"
  },
  "files": [
    "bin/",
    "agents/",
    "skills/",
    "hooks/",
    "channel/bridge.ts",
    "channel/bridge.mcp.json",
    "channel/router.ts",
    "channel/dashboard-server.ts",
    "channel/dashboard/",
    "channel/adapters/",
    "channel/slack-manifest.yml",
    "channel/package.json",
    "channel/tsconfig.json",
    "settings.json",
    "CLAUDE.md",
    ".claude-plugin/",
    ".mcp.json",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0"
  }
}
